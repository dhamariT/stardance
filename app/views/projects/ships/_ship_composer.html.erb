<section class="feed-composer"
         aria-label="Ship your project"
         data-controller="composer emoji-picker"
         data-composer-target="dropZone"
         data-composer-simple-mode-value="true"
         data-action="drop->composer#drop dragover->composer#dragover dragleave->composer#dragleave">

  <div class="feed-composer__chips">
    <span class="feed-composer__chip feed-composer__chip--active"><%= @project.title %></span>
  </div>

  <%= form_with(
        url: project_ships_path(@project),
        method: :post,
        id: "ship-form",
        html: { data: { composer_target: "form", action: "paste->composer#paste" } },
        class: "feed-composer__form",
        local: true
      ) do |form| %>

    <div class="feed-composer__main">
      <%= image_tag current_user.avatar, alt: "", class: "feed-composer__avatar" %>

      <div class="feed-composer__field">
        <%= form.label :ship_update, "What did you make?", class: "feed-composer__label" %>
        <%= form.text_area :ship_update,
              class: "feed-composer__textarea",
              rows: 1,
              required: true,
              placeholder: "What did you make? What was challenging? What are you proud of?",
              aria: { label: "Ship update" },
              data: { composer_target: "textarea",
                      emoji_picker_target: "textarea",
                      action: "focus->composer#showInfo input->composer#autogrow input->composer#refreshSubmit blur->composer#collapseIfEmpty" } %>
      </div>
    </div>

    <div class="feed-composer__toolbar">
      <div class="feed-composer__tools">
        <div class="feed-composer__emoji-wrap">
          <button type="button"
                  class="feed-composer__tool-btn"
                  aria-label="Add emoji"
                  data-emoji-picker-target="trigger"
                  data-action="emoji-picker#toggle">
            <%= inline_svg_tag "icons/emoji.svg", class: "feed-composer__tool-icon" %>
          </button>
          <div class="feed-composer__emoji-popover"
               data-emoji-picker-target="popover"
               hidden></div>
        </div>
      </div>

      <%= render ActionButtonComponent.new(
            text: "Ship and post!",
            size: :small,
            type: :submit,
            form: "ship-form",
            disable_with: "Shipping...",
            disabled: !@project.shippable?,
            class: "feed-composer__submit",
            data: { composer_target: "submit" }
          ) %>
    </div>
  <% end %>
</section>

<div class="ship__actions ship__actions--step3">
  <%= link_to "← Back", new_project_ships_path(@project, step: 2), class: "ship__back-link" %>
</div>
