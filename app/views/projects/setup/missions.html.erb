<% content_for :title, "Find a mission" %>
<main class="onboarding-screen onboarding-screen--project-missions project-setup-screen"
      data-controller="onboarding-transition">
  <%= render Projects::Setup::ProgressBarComponent.new(action: :missions) %>

  <div class="onboarding-screen__content">
    <p class="onboarding-screen__eyebrow">no worries — here are some ideas ✦</p>
    <h1 class="onboarding-screen__title onboarding-screen__title--lower">pick a mission to start with</h1>
    <p class="onboarding-screen__subhead">
      Each mission has steps to follow and a prize when you ship.
    </p>

    <% if @missions.any? %>
      <div class="project-setup-missions__grid">
        <% @missions.each do |mission| %>
          <%= form_with url: projects_setup_submit_mission_path, method: :post,
                         class: "project-setup-missions__card-form" do %>
            <%= hidden_field_tag :mission_slug, mission.slug %>
            <button type="submit"
                    class="project-setup-missions__card"
                    data-action="click->onboarding-transition#press">
              <span class="project-setup-missions__card-media" aria-hidden="true">
                <% if mission.icon.attached? %>
                  <%= image_tag mission.icon, alt: "", class: "project-setup-missions__card-icon" %>
                <% else %>
                  <span class="project-setup-missions__card-placeholder">✦</span>
                <% end %>
              </span>
              <span class="project-setup-missions__card-body">
                <span class="project-setup-missions__card-title"><%= mission.name %></span>
                <span class="project-setup-missions__card-description"><%= truncate(mission.description.to_s, length: 110) %></span>
                <% if mission.difficulty.present? || mission.steps_count > 0 %>
                  <span class="project-setup-missions__card-meta">
                    <% if mission.difficulty.present? %>
                      <span class="project-setup-missions__card-difficulty"><%= mission.difficulty %></span>
                    <% end %>
                    <% if mission.steps_count > 0 %>
                      <span class="project-setup-missions__card-steps"><%= mission.steps_count %>-step guide</span>
                    <% end %>
                  </span>
                <% end %>
              </span>
            </button>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="project-setup-missions__empty">Woah there explorer! Looks like you've already seen the whole universe (no more missions are available).</p>
    <% end %>

    <%= form_with url: projects_setup_submit_mission_path, method: :post,
                   class: "project-setup-missions__later-form" do %>
      <%= hidden_field_tag :figure_it_out_later, "1" %>
      <button type="submit" class="project-setup-missions__later"
              data-action="click->onboarding-transition#press">
        I'll figure it out later →
      </button>
    <% end %>
  </div>
</main>
